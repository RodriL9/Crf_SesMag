# https://docs.github.com/get-started/getting-started-with-git/ignoring-files

# --- Dependencies ---
node_modules/
**/node_modules/

# --- Build output ---
dist/
**/dist/
build/
**/build/
tmp/
out-tsc/
**/out-tsc/
bazel-out/

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
libpeerconnection.log
testem.log

# --- IDEs / editors ---
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
# Ignore entire VS Code folder (combine with project policy)
.vscode/
**/.vscode/
.history/

# --- Angular / TypeScript ---
.angular/
**/.angular/
.cache/
*.tsbuildinfo
.sass-cache/
connect.lock

# Karma / tooling
coverage/
**/coverage/

# Legacy typing folder (if created)
typings/

# --- OS ---
.DS_Store
Thumbs.db

# --- Frontend (optional local-only files; main global styles remain src/styles.css) ---
**/src/assets/styles.css

# --- Local docs (not tracked) ---
docs/
**/docs/
